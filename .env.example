# Required for default OpenAI-backed runs
OPENAI_API_KEY=

# Optional providers (enable matching flags in code / env — see README)
GROQ_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Optional: include extra model pools (see main.py)
# INCLUDE_GROQ_MODELS=true
# INCLUDE_GOOGLE_MODELS=true
# INCLUDE_DEEPSEEK_MODELS=true

# Per-role model overrides (optional; random pool used if unset)
# DEBATE_PROSECUTOR_MODEL=gpt-4o-mini
# DEBATE_DEFENSE_MODEL=gpt-4o-mini
# DEBATE_JUDGE_MODEL=gpt-4o-mini
# DEBATE_EVIDENCE_ANALYST_MODEL=gpt-4o-mini
# DEBATE_FACT_CHECKER_MODEL=gpt-4o-mini

